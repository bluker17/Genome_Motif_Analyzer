env.PYTHONPATH = "${projectDir}"

params {
    csv_output = "${projectDir}/testing_materials/example_outputs/DNA_test/DNA_phage_test.csv"
    fasta_files = "${projectDir}/testing_materials/example_data/DNA_test_phages/"
    motif_file = "${projectDir}/testing_materials/example_data/DNA_test_motifs.csv"
    strand = "both"
    macromolecule = "DNA"
}

manifest {
    name            = 'bluker17/Genome_Motif_Analyzer'
    author          = 'Bobby Luker'
    homePage        = 'https://github.com/bluker17/Genome_Motif_Analyzer'
    description     = 'An automated Nextflow pipeline for motif searching within FASTA entries and providing motif enrichment or depletion statistics.'
    nextflowVersion = '!>=26.04.2'
}

profiles {
    // For Conda users
    conda {
        conda.enabled          = true
        process.conda          = "${projectDir}/environment.yml"
        conda.createTimeout    = 1.h
    }

    // For Mamba users
    mamba {
        conda.enabled          = true
        conda.useMamba         = true
        process.conda          = "${projectDir}/environment.yml"
        conda.createTimeout    = 1.h
    }

    // For Micromamba users
    micromamba {
        conda.enabled          = true
        conda.useMicromamba    = true
        process.conda          = "${projectDir}/environment.yml"
        conda.createTimeout    = 1.h
    }
}